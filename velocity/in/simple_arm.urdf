<?xml version="1.0"?>
<robot name="simple_arm">
  <link name="base"/>
  <joint name="j1" type="revolute">
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <parent link="base"/>
    <child link="l1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>
  <link name="l1"/>
  <joint name="j2" type="revolute">
    <origin xyz="0.45 0 0" rpy="0 0 0"/>
    <parent link="l1"/>
    <child link="l2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>
  <link name="l2"/>
</robot>
